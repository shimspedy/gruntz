{
  "expo": {
    "name": "Gruntz",
    "slug": "gruntz",
    "owner": "blaqdu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gruntz.fitness",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMotionUsageDescription": "Gruntz uses motion sensors to count your reps during workouts.",
        "NSLocationWhenInUseUsageDescription": "Gruntz uses your location to track runs and rucks."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "package": "com.gruntz.fitness",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-notifications",
      "expo-secure-store",
      "expo-sensors",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Gruntz uses your location to track runs and rucks.",
          "locationWhenInUsePermission": "Gruntz uses your location to track runs and rucks."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6756ee93-6c12-45a9-90b3-85fc1c31cdcd"
      }
    }
  }
}
