{
  "expo": {
    "name": "Gruntz",
    "slug": "gruntz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gruntz.fitness"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "package": "com.gruntz.fitness"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-sensors",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Gruntz uses your location to track runs and rucks.",
          "locationWhenInUsePermission": "Gruntz uses your location to track runs and rucks."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Gruntz uses your camera to analyze exercise form.",
          "photosPermission": "Gruntz accesses your photos for form analysis."
        }
      ]
    ]
  }
}
